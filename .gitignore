# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/

# Compiled binaries (root level and nested)
/server
/desktop
/arkham-server
/connection_wrapper
cmd/server/arkham-server

# WebAssembly build outputs
*.wasm

# Server logs and runtime artifacts
*.log
server.log
loop.log
test-output.txt

# Analysis artifacts (go-stats-generator outputs)
baseline.json
post.json
pre-cleanup.json
post-cleanup.json
pre-cleanup-with-tests.json
*-baseline.json
*-post.json
diff-report*.json
tmp
*_test
*_server
